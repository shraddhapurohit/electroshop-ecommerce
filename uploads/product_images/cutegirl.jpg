html { scrollbar-color: rgb(200, 200, 200) transparent; }

html.dark { scrollbar-color: rgb(66, 66, 66) transparent; }

.ab-in-app-message.ab-slideup { color: var(--color-surface-foreground-0) !i=
mportant; background-color: var(--color-surface-0) !important; box-shadow: =
rgba(34, 34, 34, 0.25) 0px 0px 60px !important; border-radius: 16px !import=
ant; animation: 0.4s ease-out 0s 1 normal forwards running slideup-enter !i=
mportant; }

:is(.dark) .ab-in-app-message.ab-slideup { background-color: var(--color-su=
rface-1) !important; }

.ab-in-app-message.ab-slideup .ab-close-button svg { width: 12px !important=
; height: 12px !important; }

.ab-in-app-message.ab-slideup .ab-close-button svg path { fill: var(--color=
-surface-foreground-0) !important; }

.ab-in-app-message.ab-slideup .ab-chevron { display: none !important; }

.ab-iam-root.v3 .ab-in-app-message.ab-slideup { bottom: 0px !important; }

.ab-iam-root.v3 .ab-in-app-message .ab-message-text { font-family: var(--fo=
nt-sans),Inter,"Helvetica Neue",Helvetica,Arial,sans-serif !important; font=
-size: 0.75rem !important; line-height: 1.6 !important; letter-spacing: 0px=
 !important; font-weight: 500 !important; }

@media (max-width: 600px) {
  .ab-iam-root.v3 .ab-in-app-message.ab-slideup .ab-close-button, .ab-iam-r=
oot.v3 .ab-in-app-message.ab-slideup .ab-close-button svg:not(.ab-chevron) =
{ display: block !important; }
}

@keyframes slideup-enter {=20
  0% { transform: translateY(100%); opacity: 0; }
  100% { transform: translateY(0px); opacity: 1; }
}

.typo-heading-xs { font-size: 1.75rem; }

.typo-heading-sm, .typo-heading-xs { font-family: var(--font-sans),Inter,"H=
elvetica Neue",Helvetica,Arial,sans-serif; font-weight: 600; line-height: 1=
.375; letter-spacing: -0.01em; }

.typo-heading-sm { font-size: 2rem; }

.typo-body-2xs { font-family: var(--font-sans),Inter,"Helvetica Neue",Helve=
tica,Arial,sans-serif; font-size: 0.625rem; line-height: 1; letter-spacing:=
 0.02em; }

.typo-body-xs { font-size: 0.75rem; }

.typo-body-sm, .typo-body-xs { font-family: var(--font-sans),Inter,"Helveti=
ca Neue",Helvetica,Arial,sans-serif; line-height: 1.6; letter-spacing: 0px;=
 }

.typo-body-sm { font-size: 0.875rem; }

